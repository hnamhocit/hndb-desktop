{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "hndb",
	"version": "0.1.1",
	"identifier": "space.hndb.app",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "hndb",
				"width": 800,
				"height": 600
			}
		],
		"security": {
			"csp": null
		}
	},
	"plugins": {
		"deep-link": {
			"desktop": {
				"schemes": ["hndb"]
			}
		},
		"updater": {
			"endpoints": [
				"https://github.com/hnamhocit/hndb/releases/latest/download/latest.json"
			],
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM0ODNDODMyRTJGMzE2MkMKUldRc0Z2UGlNc2lEeE5PZDk0NmR2UTNZQkkzSk1Qdlk4TjdnRFBNeXRwZ2F5R0MwODcxYUhWWkwK"
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"createUpdaterArtifacts": true,
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
